datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// Data Induk Karyawan
model Employee {
  id        String    @id @default(cuid())
  name      String    @unique
  phone     String?
  createdAt DateTime  @default(now())
  workLogs  WorkLog[]
}

// Data Induk Jenis Karung & Stok
model BagType {
  id           String        @id @default(cuid())
  sku          String        @unique // Contoh: "PP-50KG-SUPER"
  name         String
  wagePerPiece Int           // Upah buruh per lembar karung
  currentStock Int           @default(0)
  workLogs     WorkLog[]
  sales        Transaction[]
  searchLogs   SearchLog[]
}

// Log Kerja Harian (Di-input via WhatsApp)
model WorkLog {
  id         String   @id @default(cuid())
  employeeId String
  bagTypeId  String
  quantity   Int      // Jumlah karung yang diselesaikan
  date       DateTime @default(now())
  
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  bagType    BagType  @relation(fields: [bagTypeId], references: [id], onDelete: Cascade)
}

// Arus Kas & Penjualan (Untuk Laporan Keuangan & Tren Jual)
model Transaction {
  id          String   @id @default(cuid())
  type        String   // "INCOME" (Penjualan) atau "EXPENSE" (Operasional/Beli Bahan)
  amount      Int
  description String
  bagTypeId   String?  // Nullable jika pengeluaran non-karung (misal: listrik)
  quantity    Int      @default(0) // Jumlah karung terjual
  date        DateTime @default(now())

  bagType     BagType? @relation(fields: [bagTypeId], references: [id])
}

// Log Pencarian Karung (Dari Form RFQ Website untuk Tren Pasar)
model SearchLog {
  id        String   @id @default(cuid())
  bagTypeId String
  createdAt DateTime @default(now())

  bagType   BagType  @relation(fields: [bagTypeId], references: [id])
}