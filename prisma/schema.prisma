datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// ENUMS & LOOKUPS
// ==========================================

enum TaskType {
  MENCUCI
  MELIPAT
  MENJAHIT
}

enum TransactionType {
  INCOME
  EXPENSE
}

// TAMBAHAN: Mengunci status pembayaran penjualan
enum PaymentStatus {
  LUNAS
  PENDING
}

// TAMBAHAN: Mengunci status logistik kurir armada
enum DeliveryStatus {
  DIPROSES
  DIKIRIM
  DITERIMA
}

// ==========================================
// DATA INDUK (MASTER DATA)
// ==========================================

model Employee {
  id        String    @id @default(cuid())
  name      String    @unique
  phone     String?
  createdAt DateTime  @default(now())
  workLogs  WorkLog[]
}

model BagType {
  id           String        @id @default(cuid())
  sku          String        @unique // Contoh: "PP-50KG-SUPER"
  name         String
  currentStock Int           @default(0)
  
  // Tarif borongan per aktivitas
  wageMencuci  Int           @default(0)
  wageMelipat  Int           @default(0)
  wageMenjahit Int           @default(0)
  wagePerPiece Int           @default(0) // Fallback tarif dasar

  workLogs     WorkLog[]
  transactions Transaction[]
  searchLogs   SearchLog[]
  sales        Sale[]        // TAMBAHAN: Relasi ke tabel transaksi penjualan baru
}

// ==========================================
// LOG OPERASIONAL PABRIK & PASAR
// ==========================================

model WorkLog {
  id         String   @id @default(cuid())
  employeeId String
  bagTypeId  String
  quantity   Int      // Jumlah karung yang diselesaikan
  date       DateTime @default(now())
  task       TaskType @default(MENCUCI)

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  bagType    BagType  @relation(fields: [bagTypeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([bagTypeId])
  @@index([date])
}

model SearchLog {
  id        String   @id @default(cuid())
  bagTypeId String
  createdAt DateTime @default(now())

  bagType   BagType  @relation(fields: [bagTypeId], references: [id])

  @@index([bagTypeId])
}

// ==========================================
// MODUL BARU: PENJUALAN & SURAT JALAN (OTOMATISASI)
// ==========================================

// TABEL BARU: Menampung data invoice penjualan terperinci
model Sale {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique // Contoh: "SL-9823"
  date          DateTime      @default(now())
  customerName  String        // Nama pembeli / PT tujuan
  bagTypeId     String
  quantity      Int           // Jumlah lembar karung terjual
  pricePerPiece Int           // Harga satuan karung
  totalAmount   Int           // quantity * pricePerPiece
  paymentStatus PaymentStatus @default(PENDING)

  // Relasi master karung
  bagType       BagType       @relation(fields: [bagTypeId], references: [id])
  
  // Relasi Otomatisasi (1-to-1) ke Surat Jalan & Buku Kas Keuangan
  delivery      Delivery?
  transaction   Transaction?

  @@index([bagTypeId])
  @@index([date])
}

// TABEL BARU: Menampung data kurir armada (Manifes Surat Jalan)
model Delivery {
  id              String         @id @default(cuid())
  suratJalanNo    String         @unique // Contoh: "SJ-SL-9823"
  saleId          String         @unique // Kunci 1-to-1 ke data Penjualan
  driverName      String?
  plateNumber     String?
  deliveryAddress String?        // Alamat lengkap bongkar muat gudang customer
  status          DeliveryStatus @default(DIPROSES)
  updatedAt       DateTime       @updatedAt

  // Relasi cascade: Jika data penjualan dihapus, data kurir otomatis ikut terhapus
  sale            Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

// ==========================================
// ARUS KAS KEUANGAN (LEDGER)
// ==========================================

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType 
  amount      Int
  description String
  bagTypeId   String?         // Nullable jika pengeluaran operasional non-karung
  quantity    Int             @default(0) 
  date        DateTime        @default(now())

  // TAMBAHAN: Kunci relasi opsional jika transaksi ini bersumber dari penjualan karung murni
  saleId      String?         @unique
  sale        Sale?           @relation(fields: [saleId], references: [id], onDelete: Cascade)

  bagType     BagType?        @relation(fields: [bagTypeId], references: [id])

  @@index([bagTypeId])
  @@index([date])
}